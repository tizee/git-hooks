#!/usr/bin/env bash
# Universal .git/hooks/prepare-commit-msg

# $1 is the path to the commit message file
# $2 is the type of commit

# Set default values for LLM hook environment variables
LLM_GITHOOK_SPINNER_STYLE=${LLM_GITHOOK_SPINNER_STYLE:-classic}
LLM_GITHOOK_FPS=${LLM_GITHOOK_FPS:-30}
LLM_GITHOOK_SPINNER_FPS=${LLM_GITHOOK_SPINNER_FPS:-10}
LLM_GITHOOK_STATUS_TEXT=${LLM_GITHOOK_STATUS_TEXT:-"Generating commit message…"}
LLM_GITHOOK_SHIMMER_SWEEP_SECONDS=${LLM_GITHOOK_SHIMMER_SWEEP_SECONDS:-2.0}
LLM_GITHOOK_SHIMMER_PADDING=${LLM_GITHOOK_SHIMMER_PADDING:-10}
LLM_GITHOOK_SHIMMER_BAND_WIDTH=${LLM_GITHOOK_SHIMMER_BAND_WIDTH:-5.0}

# Color configuration for shimmer animation and spinner
# Shimmer base color: bright default text color (256-color: 0-255, or TrueColor: "R,G,B")
LLM_GITHOOK_SHIMMER_BASE_COLOR=${LLM_GITHOOK_SHIMMER_BASE_COLOR:-255}
# Shimmer highlight color: dim "wave" that sweeps across (256-color: 0-255, or TrueColor: "R,G,B")
LLM_GITHOOK_SHIMMER_HIGHLIGHT_COLOR=${LLM_GITHOOK_SHIMMER_HIGHLIGHT_COLOR:-240}
# Spinner color: defaults to match shimmer base color for visual consistency
# Accepts: named (red/green/yellow/blue/magenta/cyan/white), 256-color, or TrueColor "R,G,B"
LLM_GITHOOK_SPINNER_COLOR=${LLM_GITHOOK_SPINNER_COLOR:-$LLM_GITHOOK_SHIMMER_BASE_COLOR}
# Color mode: "256" for 256-color palette, "truecolor" for 24-bit RGB
LLM_GITHOOK_COLOR_MODE=${LLM_GITHOOK_COLOR_MODE:-256}

# Skip LLM processing if we're amending AND bypass is allowed (default)
if [ "$2" = "commit" ] && git rev-parse --verify HEAD^{commit} >/dev/null 2>&1 && [ -z "$LLM_GITHOOK_NO_BYPASS_AMENDING" ]; then
    # We're amending - exit without modifying the message
    exit 0
fi

# Force UTF-8 environment (critical for Windows)
export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8
export PYTHONIOENCODING=utf-8  # If using Python-based LLM

# ANSI colors for output formatting
RED=$(printf '\033[31m')
GREEN=$(printf '\033[32m')
YELLOW=$(printf '\033[33m')
BLUE=$(printf '\033[34m')
NC=$(printf '\033[0m')

COMMIT_MSG_FILE=$1  # POSIX-compliant parameter handling

# Skip if environment variable is set
[ -n "$LLM_GITHOOK_SKIP" ] && exit 0

# Skip when not running in an interactive terminal (e.g., non‑TTY callers like CI/agents)
# Allow override with LLM_GITHOOK_FORCE or LLM_GITHOOK_ALLOW_NONINTERACTIVE
if [ -z "$LLM_GITHOOK_FORCE" ] && [ -z "$LLM_GITHOOK_ALLOW_NONINTERACTIVE" ]; then
  if [ ! -t 0 ] && [ ! -t 1 ]; then
    exit 0
  fi
fi

# Detect rebase sequences to avoid rewriting historical commit messages
GIT_DIR=${GIT_DIR:-$(git rev-parse --git-dir 2>/dev/null)}
if [ -d "$GIT_DIR/rebase-apply" ] || [ -d "$GIT_DIR/rebase-merge" ]; then
  exit 0
fi

# Exit early for merge commits
if [ "$2" = "merge" ] || [ -f "$GIT_DIR/MERGE_HEAD" ]; then
  exit 0
fi

# Function to check if `llm` is installed (with Windows support)
check_llm() {
  [ -f "$LLM_PROGRAM" ] && return 0 || return 1
}

if ! check_llm; then
  printf "%bError: $LLM_PROGRAM command not found%b\n" "$RED" "$NC" >&2
  printf "%bError: llm command not found%b\n" "$RED" "$NC" >&2
  exit 1
fi

if ! [ -f "$LLM_PREPARE_COMMIT_MSG_PROMPT" ]; then
  printf "%bError: $LLM_PREPARE_COMMIT_MSG_PROMPT file not found%b\n" "$RED" "$NC" >&2
  exit 1
fi

# Available spinner styles
SPINNER_STYLES=(
  "classic|/-\\"
  "dots|⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
  "arrows|←↖↑↗→↘↓↙"
  "blocks|▖▘▝▗"
  "pulse|▁▂▃▄▅▆▇█▇▆▅▄▃▂"
  "bouncing|⠁⠂⠄⡀⢀⠠⠐⠈"
  "circle|◐◓◑◒"
  "square|◰◳◲◱"
  "triangle|◴◵◶◷"
  "diamond|◇◈◆"
)

# Function to get spinner characters based on style
get_spinner_chars() {
  local style_name="${1:-classic}"

  for style in "${SPINNER_STYLES[@]}"; do
    if [[ "$style" == "$style_name"* ]]; then
      echo "$style" | cut -d'|' -f2
      return 0
    fi
  done

  # Fallback to classic if style not found
  echo "|/-\\"
}

# Parse color value - returns ANSI escape sequence for foreground color
# Input: color name, 256-color number, or "R,G,B" for TrueColor
# Output: ANSI escape sequence (without \033[ prefix and m suffix)
parse_color() {
  local color="$1"

  # Named colors
  case "$color" in
    black)   echo "30" ; return ;;
    red)     echo "31" ; return ;;
    green)   echo "32" ; return ;;
    yellow)  echo "33" ; return ;;
    blue)    echo "34" ; return ;;
    magenta) echo "35" ; return ;;
    cyan)    echo "36" ; return ;;
    white)   echo "37" ; return ;;
  esac

  # TrueColor RGB format: "R,G,B"
  if [[ "$color" == *,*,* ]]; then
    local r g b
    IFS=',' read -r r g b <<< "$color"
    echo "38;2;$r;$g;$b"
    return
  fi

  # 256-color number
  if [[ "$color" =~ ^[0-9]+$ ]]; then
    echo "38;5;$color"
    return
  fi

  # Fallback to white
  echo "37"
}

# Get ANSI escape code for spinner color
get_spinner_ansi() {
  local color="$LLM_GITHOOK_SPINNER_COLOR"
  local code
  code=$(parse_color "$color")
  printf '\033[%sm' "$code"
}

# -----------------------------------------------------------------------------
# Timing, shimmer rendering, and frame pacing for the spinner animation.
#
# On Windows, Git for Windows' MSYS bash has to emulate POSIX fork/exec on top
# of the native Windows process model, and that emulation costs roughly one to
# several tens of milliseconds *per spawned process* - vs. sub-millisecond
# native fork on Linux/macOS. The previous implementation spawned up to three
# external processes (a time-source binary, `awk`, and `sleep`) on *every
# single animation frame*, which by itself is enough overhead to blow a 30fps
# (33ms) frame budget on Windows, regardless of which terminal is displaying
# the output. Everything below does the per-frame work with bash builtins
# only; external processes are used at most once, at hook startup, never
# inside the render loop.
# -----------------------------------------------------------------------------

# Detect the best available high-resolution time source once. Bash's own
# $EPOCHREALTIME (bash >= 5.0, e.g. the MSYS2 bash bundled with Git for
# Windows) needs no subprocess at all, so it is tried first.
detect_time_provider() {
  if [[ -n "${EPOCHREALTIME:-}" ]]; then
    echo "bash"
    return 0
  fi

  if command -v gdate >/dev/null 2>&1; then
    echo "gdate"
    return 0
  fi

  if perl -MTime::HiRes -e 'exit 0' >/dev/null 2>&1; then
    echo "perl"
    return 0
  fi

  echo "date"
}

TIME_PROVIDER="$(detect_time_provider)"

# Kept for any external callers (e.g. scripts/shimmer-demo.sh); the hot path
# below (get_now_us) bypasses this on the bash/EPOCHREALTIME fast path to
# avoid the subshell that a `$(get_time)` command substitution would cost.
get_time() {
  case "$TIME_PROVIDER" in
    bash) printf '%s\n' "$EPOCHREALTIME" ;;
    gdate) gdate +%s.%N ;;
    perl) perl -MTime::HiRes=time -e 'printf "%.9f\n", time()' ;;
    *) date +%s ;;
  esac
}

# Sets global NOW_US to the current time in integer microseconds. On the
# EPOCHREALTIME fast path this is pure variable/arithmetic access - no
# subshell, no fork. Only the legacy fallback providers (old bash without
# EPOCHREALTIME, e.g. macOS's stock bash 3.2) still pay for a subprocess per
# call, exactly as before - no regression there, just no fast path.
NOW_US=0
get_now_us() {
  local ts sec frac
  case "$TIME_PROVIDER" in
    bash) ts="$EPOCHREALTIME" ;;
    *) ts="$(get_time)" ;;
  esac
  sec="${ts%%.*}"
  if [[ "$ts" == *.* ]]; then frac="${ts#*.}"; else frac=""; fi
  frac="${frac}000000"
  frac="${frac:0:6}"
  NOW_US=$((10#$sec * 1000000 + 10#$frac))
}

# Convert a decimal string (e.g. "2.0", "5", ".5") into an integer scaled by
# 1000 (3 fractional digits) - pure bash string/arithmetic ops, no fork. Used
# once at spinner startup to pre-convert config values; not called per frame.
to_fixed3() {
  local val="$1" int_part frac_part
  int_part="${val%%.*}"
  if [[ "$val" == *.* ]]; then frac_part="${val#*.}"; else frac_part=""; fi
  [[ -z "$int_part" ]] && int_part=0
  frac_part="${frac_part}000"
  frac_part="${frac_part:0:3}"
  printf '%d' "$((10#$int_part * 1000 + 10#$frac_part))"
}

# Precomputed lookup table for the shimmer falloff curve
# intensity(t) = 0.5 * (1 + cos(pi * t)), t in [0, 1], sampled at 65 points
# and scaled by 1000. Replaces a per-frame floating-point cos() call (bash
# has no floating point, hence the original awk dependency) with an integer
# table lookup. Max error vs. the exact curve is 1/1000 (visually identical).
SHIMMER_COS_TABLE=(
  1000 999 998 995 990 985 978 971 962 952
  941 929 916 902 887 870 854 836 817 798
  778 757 736 714 691 668 645 621 598 573
  549 525 500 475 451 427 402 379 355 332
  309 286 264 243 222 202 183 164 146 130
  113 98 84 71 59 48 38 29 22 15
  10 5 2 1 0
)

# One-time (not per-frame) setup of shimmer parameters: converts the
# user-configurable env vars into integer/fixed-point form and, for
# TrueColor mode, resolves base/highlight RGB components once instead of
# re-parsing them on every frame like the previous implementation did.
SHIMMER_SWEEP_US=2000000
SHIMMER_BAND_WIDTH_FIXED=5000
SHIMMER_USE_TRUECOLOR=0
SHIMMER_BASE_R=128; SHIMMER_BASE_G=128; SHIMMER_BASE_B=128
SHIMMER_HI_R=255; SHIMMER_HI_G=255; SHIMMER_HI_B=255

# Resolve a color spec ("R,G,B" or a 256-color grayscale index 232-255) to
# RGB components, writing globals SHIMMER_RGB_{R,G,B}. $2 is the fallback.
_shimmer_resolve_rgb() {
  local color="$1" fallback="$2"
  if [[ "$color" == *,*,* ]]; then
    IFS=',' read -r SHIMMER_RGB_R SHIMMER_RGB_G SHIMMER_RGB_B <<< "$color"
  elif [[ "$color" =~ ^[0-9]+$ ]] && (( color >= 232 && color <= 255 )); then
    local gray=$(( (color - 232) * 10 + 8 ))
    SHIMMER_RGB_R=$gray; SHIMMER_RGB_G=$gray; SHIMMER_RGB_B=$gray
  else
    SHIMMER_RGB_R=$fallback; SHIMMER_RGB_G=$fallback; SHIMMER_RGB_B=$fallback
  fi
  return 0
}

init_shimmer_params() {
  SHIMMER_SWEEP_US=$(( $(to_fixed3 "$LLM_GITHOOK_SHIMMER_SWEEP_SECONDS") * 1000 ))
  if (( SHIMMER_SWEEP_US <= 0 )); then SHIMMER_SWEEP_US=2000000; fi

  SHIMMER_BAND_WIDTH_FIXED="$(to_fixed3 "$LLM_GITHOOK_SHIMMER_BAND_WIDTH")"
  if (( SHIMMER_BAND_WIDTH_FIXED <= 0 )); then SHIMMER_BAND_WIDTH_FIXED=5000; fi

  if [[ "$LLM_GITHOOK_COLOR_MODE" == "truecolor" ]]; then
    SHIMMER_USE_TRUECOLOR=1
    _shimmer_resolve_rgb "$LLM_GITHOOK_SHIMMER_BASE_COLOR" 128
    SHIMMER_BASE_R=$SHIMMER_RGB_R; SHIMMER_BASE_G=$SHIMMER_RGB_G; SHIMMER_BASE_B=$SHIMMER_RGB_B
    _shimmer_resolve_rgb "$LLM_GITHOOK_SHIMMER_HIGHLIGHT_COLOR" 255
    SHIMMER_HI_R=$SHIMMER_RGB_R; SHIMMER_HI_G=$SHIMMER_RGB_G; SHIMMER_HI_B=$SHIMMER_RGB_B
  else
    SHIMMER_USE_TRUECOLOR=0
  fi
  return 0
}

# Render one shimmer frame into global RENDERED_SHIMMER (rather than stdout +
# a `$(...)` capture) so the per-frame call in spinner() below costs zero
# subshells. All math is bash integer arithmetic on precomputed fixed-point
# values - no forks, no floating point, functionally equivalent to the
# original awk implementation (verified numerically: max deviation of 1/256
# color levels, i.e. visually identical).
RENDERED_SHIMMER=""
render_shimmer_text() {
  local text="$1" now_us="$2" start_us="$3"
  local pad="$LLM_GITHOOK_SHIMMER_PADDING"
  local base_color="$LLM_GITHOOK_SHIMMER_BASE_COLOR"
  local highlight_color="$LLM_GITHOOK_SHIMMER_HIGHLIGHT_COLOR"
  local len=${#text}
  local period=$((len + pad * 2))

  local elapsed_us=$((now_us - start_us))
  if (( elapsed_us < 0 )); then elapsed_us=0; fi
  local pos_us=$((elapsed_us % SHIMMER_SWEEP_US))
  local center_scaled=$(( pos_us * period * 1000 / SHIMMER_SWEEP_US ))

  local out="" i i_pos_scaled dist_scaled idx intensity ch color_val r g b
  for ((i = 0; i < len; i++)); do
    i_pos_scaled=$(( (i + pad) * 1000 ))
    dist_scaled=$(( i_pos_scaled - center_scaled ))
    if (( dist_scaled < 0 )); then dist_scaled=$(( -dist_scaled )); fi

    if (( dist_scaled <= SHIMMER_BAND_WIDTH_FIXED )); then
      idx=$(( dist_scaled * 64 / SHIMMER_BAND_WIDTH_FIXED ))
      if (( idx > 64 )); then idx=64; fi
      intensity=${SHIMMER_COS_TABLE[idx]}
    else
      intensity=0
    fi

    ch="${text:i:1}"
    if (( SHIMMER_USE_TRUECOLOR )); then
      r=$(( SHIMMER_BASE_R + intensity * (SHIMMER_HI_R - SHIMMER_BASE_R) / 1000 ))
      g=$(( SHIMMER_BASE_G + intensity * (SHIMMER_HI_G - SHIMMER_BASE_G) / 1000 ))
      b=$(( SHIMMER_BASE_B + intensity * (SHIMMER_HI_B - SHIMMER_BASE_B) / 1000 ))
      out+=$'\033['"38;2;${r};${g};${b}m${ch}"
    else
      color_val=$(( base_color + intensity * (highlight_color - base_color) / 1000 ))
      if (( color_val > 255 )); then color_val=255; fi
      if (( color_val < 0 )); then color_val=0; fi
      out+=$'\033['"38;5;${color_val}m${ch}"
    fi
  done
  out+=$'\033[0m'
  RENDERED_SHIMMER="$out"
  return 0
}

# Fork-free "sleep" for frame pacing (a variant of the classic bash-hackers
# "snore" trick): open a read-write fd against a FIFO ONCE at spinner startup,
# then use the `read -t` builtin timeout against it every frame instead of
# exec'ing an external `sleep` binary per frame.
#
# IMPORTANT: the FIFO must be a *real* named pipe created with `mkfifo`, not a
# process-substitution `<(:)`. On Git for Windows / MSYS2, `<(:)` is backed by
# a temporary regular *file*, so `read` hits end-of-file immediately and the
# "wait" returns in microseconds - which silently turns frame pacing into an
# uncapped busy loop (the animation runs as fast as the CPU allows). A real
# mkfifo pipe, opened read-write so we ourselves keep the write end open and
# never see EOF, blocks for the requested timeout on Linux, macOS and Windows
# alike (verified on Git for Windows bash 5.2).
#
# Dynamic file descriptors and fractional `read -t` require Bash 4.1+. Older
# Bash versions skip the optimization and use frame_wait's `sleep` fallback.
FRAME_WAIT_FD=""
init_frame_wait() {
  local fifo
  fifo="$(mktemp -u 2>/dev/null)" || fifo="${TMPDIR:-/tmp}/llm_frame_wait_$$"
  if mkfifo "$fifo" 2>/dev/null; then
    if (( BASH_VERSINFO[0] > 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] >= 1) )); then
      { exec {FRAME_WAIT_FD}<>"$fifo"; } 2>/dev/null || FRAME_WAIT_FD=""
    fi
    rm -f "$fifo" 2>/dev/null || true
  else
    FRAME_WAIT_FD=""
  fi

  # Calibration safety net: confirm the timed read really blocks (~50ms). If it
  # returns almost instantly, the builtin wait doesn't work here - drop the fd
  # and let frame_wait fall back to `sleep`.
  if [[ -n "$FRAME_WAIT_FD" ]]; then
    local t0 t1
    get_now_us; t0=$NOW_US
    read -t 0.05 -u "$FRAME_WAIT_FD" 2>/dev/null || true
    get_now_us; t1=$NOW_US
    if (( t1 - t0 < 20000 )); then
      eval "exec ${FRAME_WAIT_FD}<&-" 2>/dev/null || true
      FRAME_WAIT_FD=""
    fi
  fi
  return 0
}

frame_wait() {
  local seconds="$1"
  if [[ -n "$FRAME_WAIT_FD" ]]; then
    read -t "$seconds" -u "$FRAME_WAIT_FD" 2>/dev/null || true
  else
    sleep "$seconds"
  fi
}

# Compute the per-frame sleep duration for a given FPS as a decimal string
# (e.g. "0.033333" for 30fps) using integer microsecond arithmetic instead of
# the previous per-call `awk` invocation (this one still only runs once).
compute_frame_interval() {
  local fps="$1"
  [[ "$fps" =~ ^[0-9]+$ ]] || fps=30
  if (( fps <= 0 )); then fps=30; fi
  local interval_us=$(( 1000000 / fps ))
  printf '%d.%06d' "$((interval_us / 1000000))" "$((interval_us % 1000000))"
}

# Function to show a spinner while fetching LLM response
spinner() {
  local style="${LLM_GITHOOK_SPINNER_STYLE:-classic}"
  local spinner_chars=$(get_spinner_chars "$style")
  local -a spinner_frames=()

  # Split the spinner glyphs into one frame per character using bash builtins
  # only (no fork). Bash substring extraction is multi-byte aware whenever the
  # locale is UTF-8, and this hook forces LC_ALL=en_US.UTF-8 above, so braille
  # and arrow glyphs split correctly on Linux, macOS (even stock bash 3.2) and
  # Git for Windows / MSYS2 alike.
  local j
  for ((j = 0; j < ${#spinner_chars}; j++)); do
    spinner_frames+=("${spinner_chars:j:1}")
  done

  init_shimmer_params

  get_now_us
  local start_us=$NOW_US

  # Spinner color ANSI code (computed once).
  local spinner_ansi
  spinner_ansi=$(get_spinner_ansi)

  # Paint the first frame RIGHT NOW, before the frame_wait FIFO calibration
  # below (a ~50ms blocking read). Otherwise the hook appears to "hang" before
  # any animation is visible.
  render_shimmer_text "$LLM_GITHOOK_STATUS_TEXT" "$NOW_US" "$start_us"
  printf "\r\033[K%s%s%b %s" "$spinner_ansi" "${spinner_frames[0]}" "$NC" "$RENDERED_SHIMMER"

  init_frame_wait

  # Render pacing: how often the shimmer is redrawn. Default 30 FPS, overridable
  # via LLM_GITHOOK_FPS. Keep this high for a smooth shimmer sweep.
  local fps="${LLM_GITHOOK_FPS:-30}"
  local frame_interval
  frame_interval="$(compute_frame_interval "$fps")"

  # Spinner glyph cadence, DECOUPLED from the render frame rate. The glyph index
  # is derived from elapsed time so the spinner rotates at a fixed, comfortable
  # speed (default 10 glyphs/sec) no matter how fast frames are rendered. Tying
  # the glyph to the frame counter (i++ per frame) made it spin at the full
  # render FPS - visually far too fast once the per-frame fork overhead that
  # used to throttle the loop was removed.
  local spinner_fps="${LLM_GITHOOK_SPINNER_FPS:-10}"
  [[ "$spinner_fps" =~ ^[0-9]+$ ]] || spinner_fps=10
  (( spinner_fps <= 0 )) && spinner_fps=10
  local spinner_interval_us=$(( 1000000 / spinner_fps ))
  local n=${#spinner_frames[@]}

  local i elapsed_us
  while :; do
    get_now_us
    elapsed_us=$((NOW_US - start_us))
    (( elapsed_us < 0 )) && elapsed_us=0
    i=$(( (elapsed_us / spinner_interval_us) % n ))
    render_shimmer_text "$LLM_GITHOOK_STATUS_TEXT" "$NOW_US" "$start_us"

    # Clear the line and redraw in-place with configurable spinner color.
    printf "\r\033[K%s%s%b %s" "$spinner_ansi" "${spinner_frames[i]}" "$NC" "$RENDERED_SHIMMER"

    frame_wait "$frame_interval"
  done
}

# Hide cursor to prevent blinking while fetching response
hide_cursor() { printf '\033[?25l'; }
show_cursor() { printf '\033[?25h'; }

# Start spinner in the background
hide_cursor
spinner 2>/dev/null &
SPIN_PID=$!

# Ensure the spinner and cursor are restored on exit
cleanup() {
  if [ -n "${SPIN_PID:-}" ] && kill -0 "$SPIN_PID" 2>/dev/null; then
    kill "$SPIN_PID" 2>/dev/null || true
    wait "$SPIN_PID" 2>/dev/null || true
  fi
  show_cursor
  printf "\r\033[K"
}
trap cleanup EXIT

# Cache files for last commit message
CACHE_DIR="$HOME/.cache/git-llm-prepare-commit-msg"
CACHE_MD5_FILE="$CACHE_DIR/last_md5"
CACHE_MSG_FILE="$CACHE_DIR/last_message"

# Create cache directory
mkdir -p "$CACHE_DIR"

# Function to calculate MD5 for staged changes
get_staged_md5() {
  # Get the diff content and file list
  local diff_content=$(git diff --staged --no-color --ignore-all-space --diff-algorithm=minimal)
  local files_list=$(git diff --staged --name-only | sort | tr '\n' ' ')

  # If nothing is staged (common when amending only the message), use the current commit contents
  if [ -z "$diff_content$files_list" ] && git rev-parse --verify HEAD^{commit} >/dev/null 2>&1; then
    diff_content=$(git show --no-color --ignore-all-space --diff-algorithm=minimal HEAD)
    files_list=$(git show --name-only --pretty=format: HEAD | sort | tr '\n' ' ')
  fi

  # Create MD5 hash of diff content and file list (GNU coreutils or macOS).
  if command -v md5sum >/dev/null 2>&1; then
    echo -n "$diff_content$files_list" | md5sum | cut -d' ' -f1
  else
    echo -n "$diff_content$files_list" | md5 -q
  fi
}

# Check if we should force regeneration
if [ -n "$LLM_GITHOOK_FORCE" ]; then
  printf "%bForcing commit message regeneration...%b\n" "$YELLOW" "$NC"
  REGENERATE=true
else
  # Check if we have cached commit message
  CURRENT_MD5=$(get_staged_md5)
  if [ -f "$CACHE_MD5_FILE" ] && [ -f "$CACHE_MSG_FILE" ]; then
    CACHED_MD5=$(cat "$CACHE_MD5_FILE")
    CACHED_MSG=$(cat "$CACHE_MSG_FILE")

    # Check if staged changes match cached
    if [ "$CURRENT_MD5" = "$CACHED_MD5" ]; then
      MSG="$CACHED_MSG"
      printf "%bUsing cached commit message...%b\n" "$YELLOW" "$NC"
      REGENERATE=false
    else
      REGENERATE=true
    fi
  else
    REGENERATE=true
  fi
fi

if [ "$REGENERATE" = true ]; then
  # Fetch staged diff content
  DIFF_CONTENT=$(git diff --staged --no-color --ignore-all-space --diff-algorithm=minimal)

  # If nothing is staged (e.g., amend message only), fall back to current commit content
  if [ -z "$DIFF_CONTENT" ] && git rev-parse --verify HEAD^{commit} >/dev/null 2>&1; then
    DIFF_CONTENT=$(git show --no-color --ignore-all-space --diff-algorithm=minimal HEAD)
  fi

  # Check if the 'commit-msg' template exists, create if missing
  if ! $LLM_PROGRAM templates show commit-msg &> /dev/null; then
    $LLM_PROGRAM prompt -s "$(cat $LLM_PREPARE_COMMIT_MSG_PROMPT)" --save commit-msg
  fi

  # Generate commit message with LLM
  if ! MSG=$(echo "$DIFF_CONTENT" | $LLM_PROGRAM prompt -t commit-msg | iconv -c -f UTF-8 -t UTF-8 2>&1); then
    printf "\n%bError: $LLM_PROGRAM failed to generate the commit message:\n%b%s%b\n\nManually set the commit message.\n" "$RED" "$NC" "$MSG" "$NC"
    exit 1
  fi

  # Cache the generated message and MD5
  echo "$CURRENT_MD5" > "$CACHE_MD5_FILE"
  echo "$MSG" > "$CACHE_MSG_FILE"
fi

# Strip leading/trailing blank lines and leading/trailing spaces per line
MSG="$(printf '%s' "$MSG" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sed '/[^[:space:]]/,$!d' | sed -e :a -e '/^[[:space:]]*$/{$d;N;ba' -e '}')"

# Stop spinner and restore cursor
cleanup

# Display generated commit message
printf "\r\033[K"
printf "%bGenerated commit message:%b\n" "$GREEN" "$NC"
printf "%b%s%b\n\n" "$YELLOW" "$MSG" "$NC"

# Get user email from git config and AI model info
USER_EMAIL=$(git config --global --get user.email)
AI_MODEL="$($LLM_PROGRAM models default --name 2>/dev/null)"

# Write output to commit message file with signed-off-by and co-authored-by footers
{
  echo "$MSG"
  echo ""
  echo "Signed-off-by: $USER_EMAIL"
  echo "Co-Authored-By: $AI_MODEL <noreply@$AI_MODEL>"
} > "$COMMIT_MSG_FILE"
