#!/bin/bash

# Pre-commit hook to detect credential leaks (API keys, tokens, passwords)
# Compatible with Unix-like systems: Unix/Linux/macOS

# Check if the environment variable DISABLE_SECRET_SCAN is set
if [ -n "$SKIP_SCAN_GITHOOK" ]; then
  echo "Skipping secret scan due to SKIP_SCAN_GITHOOK environment variable."
  exit 0
fi

# Define patterns that may represent sensitive information (tokens, passwords, API keys)
patterns=(
  "AKIA[0-9A-Z]{16}"  # AWS keys
  "AIza[0-9A-Za-z_-]{35}"  # Google API keys
  "sk_live_[0-9a-zA-Z]{24}"  # Stripe secret keys
  "-----BEGIN RSA PRIVATE KEY-----"  # RSA Private keys
  "-----BEGIN EC PRIVATE KEY-----"  # EC Private keys
  "password\s*=\s*['\"][^'\"]+['\"]"  # Common password assignment
  "token\s*=\s*['\"][^'\"]+['\"]"  # Token assignment
  "Authorization:\s*Bearer\s+[0-9a-zA-Z_-]+"  # Bearer tokens
  "^[A-Za-z0-9_-]{20,}$"  # Generic token pattern (e.g., Firebase tokens)
  "(A3T[A-Z0-9]|AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}"  # AWS Access Keys (extended)
  "(aws|AWS)?_?(SECRET|secret)?_?ACCESS?_?KEY[_=]?[A-Za-z0-9/\+=]{40}"  # AWS Secret Key pattern
  "[0-9]{12}-[0-9]{12}-[0-9]{12}"  # AWS account ID (or other common patterns)
)

# --- Color definitions for terminal output ---
if [ -t 2 ]; then
  RED='\033[0;31m'
  YELLOW='\033[1;33m'
  CYAN='\033[0;36m'
  BOLD='\033[1m'
  DIM='\033[2m'
  NC='\033[0m'
else
  RED='' YELLOW='' CYAN='' BOLD='' DIM='' NC=''
fi

# Human-readable names matching each pattern above
pattern_names=(
  "AWS Access Key"
  "Google API Key"
  "Stripe Secret Key"
  "RSA Private Key"
  "EC Private Key"
  "Password Assignment"
  "Token Assignment"
  "Bearer Token"
  "Generic Token"
  "AWS Access Key"
  "AWS Secret Key"
  "AWS Account ID"
)

# Capture the staged diff once; reused for both the fast check and the
# detailed scan below (avoids running `git diff` twice).
diff_output=$(git diff --cached)

# Build a single combined regex from all patterns for a fast, one-pass scan.
combined_pattern=""
for p in "${patterns[@]}"; do
  if [ -z "$combined_pattern" ]; then
    combined_pattern="($p)"
  else
    combined_pattern="$combined_pattern|($p)"
  fi
done

# Fast path: most commits have no secrets. Do a single grep pass over the
# added lines (strip the leading '+', skip '+++' file headers). Only when a
# potential leak is found do we fall back to the slow per-line, per-pattern
# scan that pinpoints file:line. This keeps the common case to a handful of
# process spawns instead of one grep per line per pattern.
current_file=""
current_line=0
leak_count=0
leak_messages=()

if printf '%s\n' "$diff_output" \
    | grep -E '^\+' | grep -v -E '^\+\+\+' | sed 's/^+//' \
    | grep -E -q -- "$combined_pattern"; then

  # Slow path (rare): pinpoint each leak with file:line context.
  while IFS= read -r line; do
    case "$line" in
      "diff --git "*)
        current_file="${line#* b/}"
        current_line=0
        ;;
      "@@"*)
        new_start=$(echo "$line" | sed -n 's/.*+\([0-9][0-9]*\).*/\1/p')
        current_line=${new_start:-0}
        ;;
      "+++"*)
        # diff header line, not real added content
        ;;
      "+"*)
        content="${line:1}"
        for i in "${!patterns[@]}"; do
          if echo "$content" | grep -E -q -- "${patterns[$i]}"; then
            matched=$(echo "$content" | grep -E -o -- "${patterns[$i]}" | head -1)
            leak_messages+=("  ${RED}▶${NC} ${CYAN}${current_file}${NC}:${YELLOW}${current_line}${NC}  ${BOLD}[${pattern_names[$i]}]${NC}  ${DIM}${matched}${NC}")
            ((leak_count++))
            break  # stop at first matching pattern per line to avoid duplicates
          fi
        done
        ((current_line++))
        ;;
      " "*)
        ((current_line++))
        ;;
    esac
  done < <(printf '%s\n' "$diff_output")
fi

if [ $leak_count -gt 0 ]; then
  echo "" >&2
  echo -e "${RED}${BOLD}╔══════════════════════════════════════════════════════════╗${NC}" >&2
  printf "${RED}${BOLD}║  🔒  CREDENTIAL LEAK DETECTED  —  %d issue(s) found      ║${NC}\n" "$leak_count" >&2
  echo -e "${RED}${BOLD}╚══════════════════════════════════════════════════════════╝${NC}" >&2
  echo "" >&2
  for msg in "${leak_messages[@]}"; do
    echo -e "$msg" >&2
  done
  echo "" >&2
  echo -e "  ${YELLOW}→${NC} Remove sensitive information before committing." >&2
  echo -e "  ${DIM}→ Tip: git restore --staged <file> to unstage, edit, and re-add.${NC}" >&2
  echo "" >&2
  exit 1
fi


# pre-commit: 自动格式化所有已暂存的 C/C++ 文件
changed_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(mm|m|c|h|cpp|hpp|cc|cxx)$')
if [ -z "$changed_files" ]; then
    exit 0
fi

has_clang_format() {
  local dir="$1"
  local top
  top="$(git rev-parse --show-toplevel)"

  while true; do
    if [ -f "$dir/.clang-format" ] || [ -f "$dir/_clang-format" ]; then
      return 0
    fi

    [ "$dir" = "$top" ] && return 1
    [ "$dir" = "/" ] && return 1
    dir="$(dirname "$dir")"
  done
}

for file in $changed_files; do
  case "$file" in
    *.c|*.h|*.cc|*.cpp|*.hpp)
      abs_file="$(realpath "$file")"
      dir="$(dirname "$abs_file")"

      if has_clang_format "$dir"; then
        clang-format --style=file --fallback-style=none -i "$file"
        git add "$file"
      else
        echo "skip clang-format: no .clang-format for $file"
      fi
      ;;
  esac
done

# If no leaks are detected, allow the commit to proceed
exit 0

